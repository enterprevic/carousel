# Groq API key — free at https://console.groq.com
LLM_API_KEY=your_groq_api_key_here

# LLM settings (defaults: Groq + llama-3.3-70b-versatile)
# To use a different provider, change these:
#   OpenAI:      LLM_BASE_URL=https://api.openai.com/v1/chat/completions  LLM_MODEL=gpt-4o-mini
#   OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions  LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
#   Ollama:      LLM_BASE_URL=http://host.docker.internal:11434/v1/chat/completions  LLM_MODEL=llama3.2  LLM_API_KEY=ollama
LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MODEL=llama-3.3-70b-versatile

# PostgreSQL (defaults work with docker-compose)
POSTGRES_DB=carousel
POSTGRES_USER=carousel
POSTGRES_PASSWORD=carousel

# MinIO (defaults work with docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Backend settings (auto-configured via docker-compose)
DATABASE_URL=postgresql+asyncpg://carousel:carousel@postgres:5432/carousel
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=carousel-assets
MINIO_SECURE=false

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:8000

# Auth — set JWT_SECRET to a long random string so tokens survive container restarts
#   generate one with: openssl rand -hex 32
JWT_SECRET=

# CORS — comma-separated list of allowed origins (defaults to localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
